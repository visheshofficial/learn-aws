.DS_Store

# --- Terraform / OpenTofu ---
# State files hold generated RDS master passwords and other secrets in
# plaintext — these must never be committed. Provider caches are large binaries.
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
# Real tfvars are local config; only the .example templates are committed.
*.tfvars
!*.tfvars.example

# --- Python / dbt ---
.venv/
venv/
__pycache__/
*.pyc
# dbt build artifacts and logs — regenerated on every run.
target/
dbt_packages/
logs/
# dbt connection profile — contains bucket paths and AWS profile names.
# It belongs at ~/.dbt/profiles.yml, never in the repo.
profiles.yml
!profiles.yml.example

# --- Connector jars ---
# Downloaded from GitHub releases at deploy time; large binaries, not source.
*.jar

# --- Scratch working directory ---
# Created while running the commands in
# learn-athena/athena-manual-connector-deployment.md. Contains real,
# account-specific infra details (AWS account ID, live RDS endpoint), not
# reusable project content. Delete it once your resources are torn down.
/athena-federation-demo/
